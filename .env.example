# Copy this file to .env and fill in the values before running the app.
# Never commit .env — it is in .gitignore.

# ── Backend ──────────────────────────────────────────────────────────────────
# Hosted Render backend (use this for all environments including physical device,
# simulator, and production builds — no local IP required).
EXPO_PUBLIC_API_BASE_URL=https://aira-server-7ma9.onrender.com

# ── Supabase ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── OpenAI (server-side only — do NOT add EXPO_PUBLIC_ prefix) ───────────────
# This key is used by the Express backend, never by the mobile app bundle.
OPENAI_API_KEY=your-openai-key-here
