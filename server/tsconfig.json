{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "strict":            true,
    "skipLibCheck":      true,
    "outDir":            "dist",
    "rootDir":           "..",
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../app/**",
    "../components/**",
    "../hooks/**",
    "../constants/**",
    "../lib/**"
  ]
}
